DATABASE_URL=postgresql://lvy:lvy@localhost:5432/lvy
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d
PORT=4000
CLIENT_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Supabase Storage (admin image uploads)
# SUPABASE_URL: your project URL, e.g. https://abcdefgh.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: Project Settings → API → service_role key (keep secret, server-only)
# SUPABASE_BUCKET: public bucket name (auto-created on first upload)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=lvy-media

# Email (Resend) — used for account email verification
# RESEND_API_KEY: from https://resend.com/api-keys
# MAIL_FROM: a verified sender on your Resend domain, e.g. "LVY <noreply@yourdomain.com>".
#   For quick testing use "LVY <onboarding@resend.dev>" (only delivers to your own Resend account email).
RESEND_API_KEY=
MAIL_FROM="LVY <onboarding@resend.dev>"

# SMTP (legacy / unused — Resend is the active provider)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
